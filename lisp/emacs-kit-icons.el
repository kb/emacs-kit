  "Icons for specific file extensions, keyed by style.")

(defun emacs-kit/file-icon (name)
  "Look up icon for file extension NAME in `emacs-kit/file-icons'."
  (let* ((row (assoc name emacs-kit/file-icons))
         (style (cond
                 ((memq 'nerd emacs-kit-icon-modules) :nerd)
                 ((string= (getenv "TERM") "xterm-kitty") :noicons)
                 (t :emoji)))
         (val (plist-get (cdr row) style)))
    (if (and val (char-displayable-p (string-to-char val)))
        val "")))

(provide 'emacs-kit-icons)
